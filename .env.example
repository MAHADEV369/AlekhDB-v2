# AlekhDB Environment Variables
# Copy this file to .env and fill in your keys

# Google Gemini API key (for Option 2 cognitive features)
GEMINI_API_KEY=

# OpenAI API key (for Option 2 with GPT)
OPENAI_API_KEY=

# Anthropic API key (for Option 2 with Claude)
ANTHROPIC_API_KEY=

# Ollama endpoint (default: http://localhost:11434)
OLLAMA_ENDPOINT=http://localhost:11434
