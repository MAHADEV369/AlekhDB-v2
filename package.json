    "alekhdb": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "seed": "node cli.js seed",
    "api": "node api.js",
    "doctor": "node doctor.js",
    "test": "node test_runner.js",
    "test:stress": "node extreme_stress_test.js",
    "test:elite": "node elite_test.js",
    "test:compaction": "node test_autonomous_compaction.js",
    "test:commercial": "node commercial_case_study.js",
    "test:option2": "node test_option2_gemini.js",
